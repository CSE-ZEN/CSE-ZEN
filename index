<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CSE ZEN — Votre partenaire de confiance pour les CSE</title>
<meta name="description" content="CSE ZEN accompagne les Comités Sociaux et Économiques avec une offre complète : assistance juridique, expertise comptable, formations certifiées et solutions sur-mesure.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --encre: #1B2036;
  --encre-light: #2A3150;
  --cuivre: #C4956A;
  --cuivre-light: #D4AB84;
  --cuivre-dark: #A67B52;
  --ivoire: #F7F3EE;
  --blanc: #FFFFFF;
  --gris: #6B7280;
  --gris-light: #E8E4DF;
  --text: #2D2D2D;

  /* brand colors from logo "zen" */
  --zen-red: #D93636;
  --zen-amber: #E8A020;
  --zen-blue: #2B65C8;

  --serif: 'Playfair Display', Georgia, serif;
  --sans: 'DM Sans', -apple-system, sans-serif;
}

html { scroll-behavior: smooth; }
body {
  font-family: var(--sans);
  color: var(--text);
  background: var(--blanc);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ─── NAV ─── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(27, 32, 54, 0.97);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(196, 149, 106, 0.12);
}
.nav-inner {
  max-width: 1280px; margin: 0 auto; padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  height: 72px;
}
.nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
.nav-logo img { height: 46px; width: auto; }
.nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
.nav-links a {
  color: rgba(255,255,255,0.72); text-decoration: none;
  font-size: 0.88rem; font-weight: 400; letter-spacing: 0.03em;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--cuivre-light); }
.nav-cta {
  background: var(--cuivre); color: var(--blanc) !important;
  padding: 0.55rem 1.4rem; border-radius: 6px; font-weight: 500 !important;
}
.nav-cta:hover { background: var(--cuivre-dark) !important; }
.nav-mobile-toggle {
  display: none; background: none; border: none; cursor: pointer;
  color: var(--blanc); font-size: 1.5rem;
}

/* ─── HERO ─── */
.hero {
  position: relative; min-height: 100vh;
  display: flex; align-items: center;
  background: var(--encre); overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    linear-gradient(135deg, rgba(27,32,54,0.94) 0%, rgba(27,32,54,0.72) 50%, rgba(27,32,54,0.45) 100%),
    url('https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1600&q=80') center/cover no-repeat;
}
.hero-inner {
  position: relative; z-index: 2; max-width: 1280px; margin: 0 auto;
  padding: 8rem 2rem 6rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 0.82rem; font-weight: 500;
  letter-spacing: 0.15em; text-transform: uppercase;
  margin-bottom: 1.5rem;
}
.hero-eyebrow .dot-r { color: var(--zen-red); }
.hero-eyebrow .dot-a { color: var(--zen-amber); }
.hero-eyebrow .dot-b { color: var(--zen-blue); }
.hero-eyebrow-text { color: var(--cuivre); }
.hero h1 {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 4.5vw, 3.6rem); font-weight: 500;
  color: var(--blanc); line-height: 1.15; margin-bottom: 1.5rem;
}
.hero h1 em { font-style: italic; color: var(--cuivre-light); }
.hero-sub {
  color: rgba(255,255,255,0.7); font-size: 1.1rem;
  line-height: 1.7; max-width: 520px; margin-bottom: 2.5rem;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 2rem; border-radius: 6px;
  font-family: var(--sans); font-size: 0.92rem; font-weight: 500;
  text-decoration: none; transition: all 0.25s ease; cursor: pointer; border: none;
}
.btn-primary { background: var(--cuivre); color: var(--blanc); }
.btn-primary:hover { background: var(--cuivre-dark); transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--blanc); border: 1px solid rgba(255,255,255,0.3); }
.btn-outline:hover { border-color: var(--cuivre); color: var(--cuivre-light); }

.hero-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.hero-stat {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 1.8rem; backdrop-filter: blur(8px);
}
.hero-stat-number {
  font-family: var(--serif); font-size: 2.4rem; font-weight: 600;
  line-height: 1; margin-bottom: 0.4rem;
}
.hero-stat-label { color: rgba(255,255,255,0.6); font-size: 0.82rem; line-height: 1.4; }
.stat-red .hero-stat-number { color: var(--zen-red); }
.stat-amber .hero-stat-number { color: var(--zen-amber); }
.stat-blue .hero-stat-number { color: var(--zen-blue); }
.stat-cuivre .hero-stat-number { color: var(--cuivre-light); }

/* ─── TRUST BAR ─── */
.trust {
  background: var(--ivoire);
  border-top: 1px solid var(--gris-light); border-bottom: 1px solid var(--gris-light);
  padding: 2rem 0;
}
.trust-inner {
  max-width: 1280px; margin: 0 auto; padding: 0 2rem;
  display: flex; align-items: center; justify-content: center;
  gap: 3rem; flex-wrap: wrap;
}
.trust-label {
  font-size: 0.78rem; color: var(--gris); text-transform: uppercase;
  letter-spacing: 0.1em; font-weight: 500; white-space: nowrap;
}
.trust-logos { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; }
.trust-logo {
  font-family: var(--sans); font-size: 1.1rem; font-weight: 600;
  color: var(--encre); opacity: 0.35; letter-spacing: 0.02em;
}

/* ─── SECTION UTILITY ─── */
.section { padding: 6rem 2rem; }
.section-dark { background: var(--encre); color: var(--blanc); }
.section-ivoire { background: var(--ivoire); }
.container { max-width: 1280px; margin: 0 auto; }
.section-header { max-width: 640px; margin-bottom: 4rem; }
.section-header.centered { text-align: center; margin-left: auto; margin-right: auto; }
.section-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  color: var(--cuivre); font-size: 0.78rem; font-weight: 500;
  letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1rem;
}
.section-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--cuivre); }
.section-title {
  font-family: var(--serif);
  font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 500;
  line-height: 1.2; margin-bottom: 1rem;
}
.section-title em { font-style: italic; color: var(--cuivre); }
.section-desc { font-size: 1.05rem; color: var(--gris); line-height: 1.7; }
.section-dark .section-desc { color: rgba(255,255,255,0.6); }

/* ─── POLES ─── */
.poles-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.pole-card {
  position: relative; border-radius: 12px; overflow: hidden;
  aspect-ratio: 3/4; cursor: pointer;
}
.pole-card-bg {
  position: absolute; inset: 0; background-size: cover; background-position: center;
  transition: transform 0.5s ease;
}
.pole-card:hover .pole-card-bg { transform: scale(1.05); }
.pole-card-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(27,32,54,0.08) 0%, rgba(27,32,54,0.82) 65%, rgba(27,32,54,0.96) 100%);
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 2rem 1.5rem;
}
.pole-accent {
  width: 36px; height: 3px; border-radius: 2px;
  margin-bottom: 1rem;
}
.pole-accent-red { background: var(--zen-red); }
.pole-accent-amber { background: var(--zen-amber); }
.pole-accent-blue { background: var(--zen-blue); }
.pole-accent-cuivre { background: var(--cuivre); }
.pole-name {
  font-family: var(--serif); font-size: 1.25rem; font-weight: 600;
  color: var(--blanc); margin-bottom: 0.15rem;
}
.pole-name-zen { font-weight: 400; opacity: 0.7; font-size: 0.95em; }
.pole-desc {
  font-size: 0.84rem; color: rgba(255,255,255,0.6); line-height: 1.5;
  margin-top: 0.5rem;
}
.pole-link {
  display: inline-flex; align-items: center; gap: 0.3rem;
  color: var(--cuivre-light); font-size: 0.82rem; font-weight: 500;
  margin-top: 0.8rem; text-decoration: none; transition: gap 0.2s;
}
.pole-card:hover .pole-link { gap: 0.6rem; }

/* ─── APPROACH ─── */
.approach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.approach-card {
  padding: 2.5rem 2rem;
  border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
  background: rgba(255,255,255,0.03);
  transition: border-color 0.3s, background 0.3s;
}
.approach-card:hover { border-color: rgba(196,149,106,0.3); background: rgba(196,149,106,0.05); }
.approach-icon {
  width: 44px; height: 44px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; margin-bottom: 1.5rem; font-weight: 700;
  font-family: var(--sans);
}
.approach-icon-r { background: rgba(217,54,54,0.12); color: var(--zen-red); }
.approach-icon-a { background: rgba(232,160,32,0.12); color: var(--zen-amber); }
.approach-icon-b { background: rgba(43,101,200,0.12); color: var(--zen-blue); }
.approach-icon-c { background: rgba(196,149,106,0.15); color: var(--cuivre-light); }
.approach-title {
  font-family: var(--serif); font-size: 1.12rem; font-weight: 600;
  color: var(--blanc); margin-bottom: 0.6rem;
}
.approach-desc { font-size: 0.88rem; color: rgba(255,255,255,0.55); line-height: 1.6; }

/* ─── ABOUT / SPLIT ─── */
.split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.split-image { border-radius: 16px; overflow: hidden; aspect-ratio: 4/3; }
.split-image img { width: 100%; height: 100%; object-fit: cover; }
.split-content .section-header { margin-bottom: 2rem; }
.values-list { display: flex; flex-direction: column; gap: 1.2rem; }
.value-item { display: flex; gap: 1rem; align-items: flex-start; }
.value-marker {
  flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%; margin-top: 0.5rem;
}
.vm-red { background: var(--zen-red); }
.vm-amber { background: var(--zen-amber); }
.vm-blue { background: var(--zen-blue); }
.value-text { font-size: 0.95rem; color: var(--text); line-height: 1.5; }
.value-text strong { color: var(--encre); }
.certifs {
  display: flex; align-items: center; gap: 2rem; margin-top: 2rem;
  padding-top: 2rem; border-top: 1px solid var(--gris-light);
}
.certif-badge {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.8rem; color: var(--gris); font-weight: 500;
}
.certif-dot {
  width: 28px; height: 28px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 700;
}
.certif-qualiopi .certif-dot { background: rgba(43,101,200,0.1); color: var(--zen-blue); }
.certif-dreets .certif-dot { background: rgba(217,54,54,0.1); color: var(--zen-red); }

/* ─── TESTIMONIALS ─── */
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.testimonial-card {
  background: var(--blanc); border: 1px solid var(--gris-light);
  border-radius: 12px; padding: 2rem; transition: border-color 0.3s;
}
.testimonial-card:hover { border-color: var(--cuivre); }
.testimonial-stars { color: var(--zen-amber); font-size: 0.85rem; margin-bottom: 1rem; letter-spacing: 0.1em; }
.testimonial-text {
  font-size: 0.92rem; color: var(--text); line-height: 1.65;
  margin-bottom: 1.5rem; font-style: italic;
}
.testimonial-author { display: flex; align-items: center; gap: 0.8rem; }
.testimonial-avatar {
  width: 40px; height: 40px; border-radius: 50%; background: var(--encre);
  display: flex; align-items: center; justify-content: center;
  color: var(--cuivre); font-family: var(--serif); font-size: 0.9rem; font-weight: 600;
}
.testimonial-name { font-size: 0.88rem; font-weight: 600; color: var(--encre); }
.testimonial-role { font-size: 0.78rem; color: var(--gris); }

/* ─── TEAM ─── */
.team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.team-member { text-align: center; }
.team-photo {
  width: 100%; aspect-ratio: 1; border-radius: 12px; overflow: hidden;
  margin-bottom: 1rem; background: var(--ivoire);
}
.team-photo img {
  width: 100%; height: 100%; object-fit: cover;
  filter: grayscale(15%); transition: filter 0.3s;
}
.team-member:hover .team-photo img { filter: grayscale(0%); }
.team-name {
  font-family: var(--serif); font-size: 1rem; font-weight: 600;
  color: var(--encre); margin-bottom: 0.2rem;
}
.team-role { font-size: 0.8rem; color: var(--cuivre); font-weight: 500; }
.team-org { font-size: 0.75rem; color: var(--gris); margin-top: 0.15rem; }

.partners-row {
  display: flex; justify-content: center; gap: 3rem; margin-top: 3rem;
  padding-top: 3rem; border-top: 1px solid var(--gris-light); flex-wrap: wrap;
}
.partner-logo { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
.partner-logo-mark {
  width: 80px; height: 80px; border-radius: 12px; background: var(--blanc);
  border: 1px solid var(--gris-light);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--serif); font-size: 0.82rem; font-weight: 700;
  color: var(--encre); line-height: 1.1; text-align: center; padding: 0.5rem;
}
.partner-logo-label {
  font-size: 0.72rem; color: var(--gris); text-transform: uppercase; letter-spacing: 0.08em;
}

/* ─── CTA ─── */
.cta-section {
  background: var(--encre); padding: 6rem 2rem; text-align: center;
  position: relative; overflow: hidden;
}
.cta-section::before {
  content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
  background: radial-gradient(ellipse at center, rgba(196,149,106,0.08) 0%, transparent 60%);
}
.cta-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
.cta-title {
  font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 2.8rem);
  color: var(--blanc); font-weight: 500; line-height: 1.2; margin-bottom: 1rem;
}
.cta-title em { font-style: italic; color: var(--cuivre-light); }
.cta-sub { color: rgba(255,255,255,0.6); font-size: 1.05rem; margin-bottom: 2.5rem; line-height: 1.6; }
.cta-contact-info {
  display: flex; justify-content: center; gap: 2.5rem; margin-top: 2rem; flex-wrap: wrap;
}
.cta-contact-item {
  color: rgba(255,255,255,0.5); font-size: 0.88rem;
  text-decoration: none; transition: color 0.2s;
}
.cta-contact-item:hover { color: var(--cuivre-light); }

/* ─── FOOTER ─── */
.footer {
  background: #111528; padding: 3rem 2rem 2rem;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.footer-inner {
  max-width: 1280px; margin: 0 auto;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 1rem;
}
.footer-logo {
  display: flex; align-items: center; gap: 0.6rem;
}
.footer-logo img { height: 32px; width: auto; opacity: 0.6; }
.footer-legal { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
.footer-links { display: flex; gap: 1.5rem; }
.footer-links a {
  font-size: 0.8rem; color: rgba(255,255,255,0.4);
  text-decoration: none; transition: color 0.2s;
}
.footer-links a:hover { color: var(--cuivre-light); }

/* ─── RESPONSIVE ─── */
@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; gap: 3rem; padding-top: 7rem; }
  .hero-stats { grid-template-columns: repeat(4, 1fr); }
  .poles-grid { grid-template-columns: repeat(2, 1fr); }
  .approach-grid { grid-template-columns: repeat(2, 1fr); }
  .split { grid-template-columns: 1fr; gap: 2.5rem; }
  .team-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-mobile-toggle { display: block; }
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
  .poles-grid { grid-template-columns: 1fr; }
  .pole-card { aspect-ratio: 16/9; }
  .approach-grid { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .team-grid { grid-template-columns: repeat(2, 1fr); }
  .section { padding: 4rem 1.5rem; }
}
</style>
</head>
